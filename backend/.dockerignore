# Version control
.git
.gitignore

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Virtualenvs
.venv/
venv/
env/

# Local secrets / config — never bake into an image
.env
.env.*
!.env.example

# Test / coverage output
.coverage
htmlcov/
coverage.xml

# Editor / OS cruft
.vscode/
.idea/
*.swp
.DS_Store

# Docs are not needed in the runtime image
docs/
*.md
!README.md
